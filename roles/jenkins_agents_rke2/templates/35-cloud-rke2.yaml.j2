# purpose: Jenkins JCasC - Kubernetes cloud for RKE2 agents
# adr: ADR-0603-run-jenkins-controller-on-control-node-agents-on-rke2
# maintainer: HybridOps.Studio

credentials:
  system:
    domainCredentials:
      - credentials:
          - string:
              scope: GLOBAL
              id: "{{ jenkins_agents_rke2_credentials_id }}"
              description: "RKE2 ServiceAccount token for Jenkins Kubernetes plugin"
              secret: "{{ jenkins_agents_rke2_k8s_token }}"

{% if (jenkins_agents_rke2_ca_cert_pem | default('') | string | trim | length) > 0 %}
unclassified:
  globalConfigFiles:
    configs: []
{% endif %}

jenkins:
  clouds:
    - kubernetes:
        name: "{{ jenkins_agents_rke2_cloud_name }}"
        serverUrl: "{{ jenkins_agents_rke2_server_url }}"
        namespace: "{{ jenkins_agents_rke2_namespace }}"
        skipTlsVerify: {{ (jenkins_agents_rke2_skip_tls_verify | bool) | lower }}
        credentialsId: "{{ jenkins_agents_rke2_credentials_id }}"

        jenkinsUrl: "{{ jenkins_agents_rke2_jenkins_url }}"
{% if (jenkins_agents_rke2_jenkins_tunnel | default('') | string | trim | length) > 0 %}
        jenkinsTunnel: "{{ jenkins_agents_rke2_jenkins_tunnel }}"
{% endif %}

        containerCapStr: "{{ jenkins_agents_rke2_instance_cap | int }}"
        retentionTimeout: {{ (jenkins_agents_rke2_idle_minutes | int) * 60 }}

        templates:
          - name: "{{ jenkins_agents_rke2_label }}"
            namespace: "{{ jenkins_agents_rke2_namespace }}"
            label: "{{ jenkins_agents_rke2_label }}"
            serviceAccount: "{{ jenkins_agents_rke2_service_account_name }}"
            idleMinutes: {{ jenkins_agents_rke2_idle_minutes | int }}

            containers:
              - name: "jnlp"
                image: "{{ jenkins_agents_rke2_agent_image }}"
                workingDir: "{{ jenkins_agents_rke2_agent_workdir }}"
                ttyEnabled: true
                alwaysPullImage: true
                resourceRequestCpu: "200m"
                resourceRequestMemory: "256Mi"
                resourceLimitCpu: "2000m"
                resourceLimitMemory: "2048Mi"
                envVars:
                  - envVar:
                      key: "JENKINS_WEB_SOCKET"
                      value: "{{ (jenkins_agents_rke2_use_websocket | bool) | ternary('true','false') }}"