# purpose: Jenkins Configuration as Code credentials (bootstrap only)
# adr: ADR-0603-run-jenkins-controller-on-control-node-agents-on-rke2
# maintainer: HybridOps.Studio

{% set vault_pass = jenkins_ansible_vault_password | default('') | string | trim %}

credentials:
  system:
    domainCredentials:
      - credentials:
{% if vault_pass|length > 0 %}
          - string:
              scope: GLOBAL
              id: "ansible-vault-password"
              description: "Ansible vault password (CI bootstrap)"
              secret: "{{ vault_pass }}"
{% endif %}
{% if jenkins_casc_secrets_enabled | bool %}
          - file:
              scope: GLOBAL
              id: "gcp-runner-sa"
              description: "GCP runner service account key (file)"
              fileName: "ci-runner-sa.json"
              secretBytes: "${readFileBase64:/var/jenkins_home/casc_secrets/gcp/ci-runner-sa.json}"
{% endif %}
