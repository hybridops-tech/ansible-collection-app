# purpose: Docker Compose definition for Jenkins controller
# adr: ADR-0603-run-jenkins-controller-on-control-node-agents-on-rke2
# maintainer: HybridOps.Studio

services:
  jenkins-controller:
    image: "{{ jenkins_controller_image }}:{{ jenkins_version }}"
    container_name: "{{ jenkins_container_name }}"
    restart: unless-stopped
    user: "{{ jenkins_uid }}:{{ jenkins_gid }}"
    networks:
      - "{{ jenkins_network_name }}"
    ports:
      - "{{ jenkins_external_http_port }}:{{ jenkins_http_port }}"
      - "{{ jenkins_external_agent_port }}:{{ jenkins_agent_port }}"
    volumes:
      - "{{ jenkins_home_path }}/jenkins_home:/var/jenkins_home"
      - "/var/run/docker.sock:/var/run/docker.sock"
    environment:
      - JENKINS_HOME=/var/jenkins_home
      - CASC_JENKINS_CONFIG=/var/jenkins_home/casc_configs
      - JAVA_OPTS=-Djenkins.install.runSetupWizard=false -Xmx{{ jenkins_memory }}
      - COLLECTING_METRICS_PERIOD_IN_SECONDS={{ jenkins_prometheus_collecting_metrics_period_seconds | default(120) }}
{% if jenkins_enable_healthcheck %}
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:{{ jenkins_http_port }}/login >/dev/null || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
{% endif %}

networks:
  {{ jenkins_network_name }}:
    external: true
